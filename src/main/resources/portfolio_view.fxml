<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<VBox spacing="20.0" styleClass="root" stylesheets="@styles/theme.css" xmlns="http://javafx.com/javafx/19" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stockapp.auth.PortfolioController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20.0">
        <Button text="Back" onAction="#goBack" styleClass="back-button" />
        <Label text="My Portfolio" styleClass="title" />
    </HBox>

    <TableView fx:id="portfolioTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="tickerColumn" text="Symbol" prefWidth="100.0" />
            <TableColumn fx:id="quantityColumn" text="Quantity" prefWidth="100.0" />
            <TableColumn fx:id="avgPriceColumn" text="Avg Price" prefWidth="120.0" />
            <TableColumn fx:id="currentPriceColumn" text="Current Price" prefWidth="120.0" />
            <TableColumn fx:id="marketValueColumn" text="Market Value" prefWidth="120.0" />
            <TableColumn fx:id="profitLossColumn" text="P/L" prefWidth="100.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>
</VBox>
