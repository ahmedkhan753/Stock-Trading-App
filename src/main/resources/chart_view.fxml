<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.stockapp.auth.ChartController" stylesheets="@style.css">
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" right="20" bottom="10" left="20"/>
            </padding>
            <Label text="Stock Price History" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <HBox alignment="CENTER" spacing="15">
                <Label text="Select Stock:" style="-fx-text-fill: white;"/>
                <ComboBox fx:id="stockComboBox" prefWidth="200"/>
                <Button text="Show All" onAction="#handleShowAll"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <LineChart fx:id="priceChart" title="Price History" createSymbols="false">
            <xAxis>
                <CategoryAxis fx:id="xAxis" label="Time" side="BOTTOM" />
            </xAxis>
            <yAxis>
                <NumberAxis fx:id="yAxis" label="Price ($)" side="LEFT" />
            </yAxis>
        </LineChart>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="10" right="20" bottom="20" left="20"/>
            </padding>
            <Button text="Close" onAction="#handleClose" styleClass="button-secondary"/>
        </HBox>
    </bottom>
</BorderPane>
